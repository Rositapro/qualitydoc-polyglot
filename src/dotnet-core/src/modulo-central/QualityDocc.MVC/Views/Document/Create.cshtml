@{
    ViewData["Title"] = "Subir Nuevo Documento";
}

<div class="container mt-4">
    <h2>Subir Nuevo Documento</h2>
    <hr />

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="form-group mb-3">
            <label class="control-label">Título del documento</label>
            <input type="text" name="title" class="form-control" required placeholder="Ej: Manual de Calidad 2024" />
        </div>

        <div class="form-group mb-3">
            <label class="control-label">Archivo PDF</label>
            <input type="file" name="file" class="form-control" accept=".pdf" required />
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Guardar Documento</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>