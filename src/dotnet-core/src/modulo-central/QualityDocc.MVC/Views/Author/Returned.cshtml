@model IEnumerable<QualityDocc.Domain.Entities.Document>

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Documentos Devueltos";
}

<div class="container-fluid py-4" style="background-color: #ffffff; min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #333; font-weight: 700;">
            <i class="bi bi-arrow-return-left me-2" style="color: #734F31;"></i> Documentos Devueltos
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver al Dashboard</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead style="border-bottom: 2px solid #E8D1A7;">
                <tr>
                    <th scope="col" style="color: #734F31;">ID</th>
                    <th scope="col" style="color: #734F31;">Título</th>
                    <th scope="col" style="color: #734F31;">Norma ISO</th>
                    <th scope="col" style="color: #734F31;">Nota del Revisor</th>
                    <th scope="col" style="color: #734F31;">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var doc in Model)
                    {
                        <tr>
                            <td class="fw-bold">@doc.Id</td>
                            <td>@doc.Title</td>
                            <td>@(doc.Iso?.Name ?? "N/A")</td>

                            <td class="text-danger fst-italic">
                                <i class="bi bi-exclamation-circle me-1"></i> @doc.RejectionNotes
                            </td>

                            <td>
                                <a asp-controller="Author" asp-action="Upload" asp-route-id="@doc.Id" class="btn btn-sm text-white" style="background-color: #9D9167;">
                                    <i class="bi bi-pencil-square me-1"></i> Corregir
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            ¡Felicidades! No tienes documentos devueltos.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>