<!-- Views/Shared/_Layout.cshtml -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QualityDoc - Panel de Control (.NET)</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- Google Fonts (Lora, Playfair Display y Plus Jakarta Sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Lora:ital,wght@0,400..700;1,400..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
            :root {
                --bg-color: #f7f4ed;            /* Crema/Beige muy claro para el fondo */
                --card-bg: rgba(255, 255, 255, 0.95);
                --border-color: #e5dec9;        /* Borde beige suave */
                
                --color-primary: #5c3a21;       /* Café Chocolate */
                --color-primary-hover: #4a2e1a; /* Café más oscuro */
                --color-accent: #c5a059;        /* Bronce/Oro viejo */
                --color-accent-hover: #b48e47;  
                --color-dark: #23170f;          /* Espresso casi negro */
                
                --text-main: #332720;           /* Café oscuro para lectura */
                --text-muted: #72635a;          /* Café grisáceo */
            }

            body {
                background-color: var(--bg-color);
                color: var(--text-main);
                font-family: 'Lora', serif;
                font-size: 1rem;
                line-height: 1.6;
                min-height: 100vh;
                display: flex;
            }

            h1, h2, h3, h4, h5, h6, .brand-font {
                font-family: 'Playfair Display', serif;
                color: var(--color-dark);
                font-weight: 700;
            }

            /* Sidebar al estilo PHP (Chocolate/Espresso Oscuro) */
            .sidebar {
                width: 280px;
                background-color: var(--color-dark);
                color: #f5efe6;
                display: flex;
                flex-direction: column;
                padding: 1.5rem;
                box-shadow: 4px 0 15px rgba(0, 0, 0, 0.15);
                z-index: 100;
                border-right: none !important;
                flex-shrink: 0;
            }

            .sidebar-header {
                padding-bottom: 1.5rem;
                border-bottom: 1px solid rgba(197, 160, 89, 0.2);
                margin-bottom: 1.5rem;
            }

            .sidebar-brand {
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--color-accent);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-family: 'Playfair Display', serif;
            }

            .sidebar-brand .brand-font {
                color: inherit !important;
                margin-left: 0.25rem;
            }

            .sidebar-brand i {
                font-size: 1.7rem;
            }

            .sidebar-brand:hover {
                color: #fff;
            }

            .nav-menu {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                flex-grow: 1;
            }

            .nav-item-link {
                display: flex;
                align-items: center;
                gap: 1rem;
                padding: 0.8rem 1rem;
                color: #dfd7cb !important;
                text-decoration: none;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 0.95rem;
                border-radius: 6px;
                transition: all 0.25s ease;
                border-left: 3px solid transparent;
            }

            .nav-item-link i {
                font-size: 1.2rem;
                color: var(--color-accent);
                transition: transform 0.25s ease;
            }

            .nav-item-link:hover {
                background-color: rgba(197, 160, 89, 0.1);
                color: #fff !important;
                border-left-color: var(--color-accent);
                padding-left: 1.25rem;
            }

            .nav-item-link:hover i {
                transform: scale(1.1);
            }

            .nav-item-link.active {
                background-color: var(--color-primary);
                color: #fff !important;
                border-left-color: var(--color-accent);
            }

            .nav-item-link.active i {
                color: #fff;
            }

            /* Override de la clase dashboard-bg de las vistas internas */
            .dashboard-bg {
                background-color: transparent !important;
                padding: 0 !important;
                min-height: auto !important;
                color: var(--text-main) !important;
            }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/Home/Index" class="sidebar-brand">
                <i class="bi bi-journal-bookmark-fill"></i>
                <span class="brand-font">QualityDoc</span>
            </a>
        </div>
        <nav class="flex-grow-1">
            <ul class="nav-menu">
                @await Html.PartialAsync("_Sidebar")
            </ul>
        </nav>
    </aside>

    <main class="flex-grow-1 p-4" style="overflow-y: auto;">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded shadow-sm" style="background-color: #ffffff; border: 1px solid #e5dec9; color: #332720;">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-check text-warning fs-5"></i>
                    <span class="fw-bold" style="font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #23170f;">Acceso Seguro (.NET)</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="user-profile-badge d-flex align-items-center gap-2 px-3 py-1.5 rounded-pill" style="background-color: #f3efe6; border: 1px solid #e5dec9; color: #5c3a21; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem;">
                        <i class="bi bi-person-circle fs-5 text-warning"></i>
                        <span class="fw-bold">@User.Identity.Name</span>
                        @{
                            var userRole = "";
                            var roleBgColor = "#72635a"; // default
                            if (User.IsInRole("SuperAdmin"))
                            {
                                userRole = "SuperAdmin";
                                roleBgColor = "#8b0000"; // dark red
                            }
                            else if (User.IsInRole("Administrator"))
                            {
                                userRole = "Admin";
                                roleBgColor = "#0d6efd"; // blue
                            }
                            else if (User.IsInRole("Reviewer"))
                            {
                                userRole = "Revisor";
                                roleBgColor = "#6f42c1"; // purple
                            }
                            else if (User.IsInRole("Author"))
                            {
                                userRole = "Autor";
                                roleBgColor = "#198754"; // green
                            }
                            else if (User.IsInRole("Approver"))
                            {
                                userRole = "Aprobador";
                                roleBgColor = "#fd7e14"; // orange
                            }
                            else if (User.IsInRole("Reader"))
                            {
                                userRole = "Lector";
                                roleBgColor = "#6c757d"; // gray
                            }
                        }
                        <span class="badge" style="font-size: 0.75rem; background-color: @roleBgColor !important; color: #ffffff;">@userRole</span>
                    </div>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Script para activar los enlaces en base al URL actual -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname.toLowerCase();
            const navLinks = document.querySelectorAll('.sidebar .nav-item-link');
            navLinks.forEach(link => {
                const href = link.getAttribute('href');
                if (href) {
                    const hrefLower = href.toLowerCase();
                    if (currentPath === hrefLower || (hrefLower !== '/' && hrefLower !== '/home/index' && currentPath.startsWith(hrefLower))) {
                        link.classList.add('active');
                    }
                }
            });
        });
    </script>
</body>
</html>