@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <a href="/Home/Index" class="nav-link"><i class="bi bi-house-door-fill"></i> Inicio</a>
}

@if (User.IsInRole("Author"))
{
    <a href="/Author/Index" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard Autor</a>
    <a href="/Author/Upload" class="nav-link"><i class="bi bi-upload"></i> Subir Documento</a>
    <a href="/Author/Search" class="nav-link"><i class="bi bi-search"></i> Buscar Documentos</a>
    <a href="/Author/Returned" class="nav-link"><i class="bi bi-arrow-return-left"></i> Devueltos</a>
}

@if (User.IsInRole("Reviewer"))
{
    <a href="/Reviewer/Index" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard Revisor</a>
    <a href="/Reviewer/Pending" class="nav-link"><i class="bi bi-clipboard-check"></i> Pendientes de Revisión</a>
}

@if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator"))
{
    <a href="/Admin/Dashboard" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard Admin</a>
    <a href="/Admin/Users" class="nav-link"><i class="bi bi-people"></i> Gestionar Usuarios</a>
    @if (User.IsInRole("SuperAdmin"))
    {
        <a href="/Admin/Companies" class="nav-link"><i class="bi bi-building"></i> Gestionar Empresas</a>
    }
    <a href="/Admin/Isos" class="nav-link"><i class="bi bi-shield-check"></i> Gestión de ISO</a>
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <hr class="text-white opacity-50 my-4" style="border-width: 1px;" />

    <a href="/Auth/Logout" class="nav-link text-danger" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
        <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
    </a>
}