@if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator"))
{
    <li>
        <a href="/Admin/Dashboard" class="nav-item-link">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard Admin</span>
        </a>
    </li>
    <li>
        <a href="/Admin/Users" class="nav-item-link">
            <i class="bi bi-people"></i>
            <span>Gestionar Usuarios</span>
        </a>
    </li>
    @if (User.IsInRole("SuperAdmin"))
    {
        <li>
            <a href="/Admin/Companies" class="nav-item-link">
                <i class="bi bi-building"></i>
                <span>Gestionar Empresas</span>
            </a>
        </li>
    }
    <li>
        <a href="/Admin/Isos" class="nav-item-link">
            <i class="bi bi-shield-check"></i>
            <span>Gestión de ISO</span>
        </a>
    </li>
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="border-top border-secondary pt-3 mt-4">
        <a href="/Auth/Logout" class="btn btn-sm btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2" style="font-family: 'Plus Jakarta Sans', sans-serif;">
            <i class="bi bi-box-arrow-left"></i>
            <span>Cerrar Sesión</span>
        </a>
    </div>
}