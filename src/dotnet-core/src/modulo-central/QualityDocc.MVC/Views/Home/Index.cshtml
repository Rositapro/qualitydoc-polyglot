@model IEnumerable<QualityDocc.Application.DTOs.DocumentDto>
@{
    ViewData["Title"] = "Panel de Control de Documentos - QualityDoc";
}

<div class="container-fluid py-4 animate-fade-in" style="font-family: 'Lato', sans-serif;">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid #e5dec9;">
        <div>
            <h1 style="font-family: 'Playfair Display', serif; font-weight: 700; color: var(--color-primary); margin: 0;">Gestión Core de Documentos</h1>
            <p class="text-muted mb-0" style="font-style: italic; color: var(--text-muted) !important;">Ciclo de vida normativo e integridad de versiones (SQL Server)</p>
        </div>
        <div>
        </div>
    </div>

    <!-- Tarjeta de Bienvenida Estilo Premium -->
    <div class="card mb-4 border-0 position-relative overflow-hidden shadow-sm animate-fade-in" style="background-color: #ffffff; border-radius: 16px; border: 1px solid #e5dec9; color: var(--text-main);">
        <div class="position-absolute end-0 top-50 translate-middle-y pe-5 d-none d-md-block" style="font-size: 8rem; pointer-events: none; color: var(--color-primary); opacity: 0.06; z-index: 0;">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div class="card-body p-4 p-md-5" style="position: relative; z-index: 1;">
            <span class="badge px-3 py-2 mb-3 rounded-pill text-uppercase fw-semibold" style="background-color: var(--color-primary); color: #ffffff; letter-spacing: 0.05em; font-size: 0.75rem;">
                Módulo Central .NET Core Activo
            </span>
            <h2 class="display-6 fw-bold mb-3" style="font-family: 'Playfair Display', serif; color: var(--color-primary);">
                ¡Te damos la bienvenida, @(User.Identity?.Name ?? "Administrador")!
            </h2>
            <p class="lead mb-4" style="font-size: 1.05rem; max-width: 750px; color: var(--text-muted) !important;">
                Estás en el panel de control central de QualityDocc. Desde aquí puedes supervisar el ciclo de vida de los documentos, gestionar la seguridad de los tenants y clasificar la información según estándares de calidad internacionales.
            </p>
            <div class="d-flex flex-wrap gap-3">
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator"))
                {
                    <a href="/Admin/Dashboard" class="btn px-4 py-2 text-white fw-bold" style="background-color: var(--color-primary); border-radius: 8px; text-decoration: none;">
                        <i class="bi bi-speedometer2 me-2"></i> Panel de Administración
                    </a>
                    <a href="/Admin/Users" class="btn btn-outline-primary px-4 py-2" style="border-radius: 8px; color: var(--color-primary); border-color: var(--color-primary); text-decoration: none;">
                        <i class="bi bi-people me-2"></i> Gestionar Usuarios
                    </a>
                }
            </div>
        </div>
    </div>

</div>