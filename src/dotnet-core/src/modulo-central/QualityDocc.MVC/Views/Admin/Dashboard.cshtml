@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Panel de Administración Global";
}

<div class="container-fluid py-4" style="color: #F5EBE1;">
    <div class="welcome-text mb-4">
        <h2 class="fw-bold" style="color: #ffffff;"><i class="bi bi-speedometer2 me-2"></i>Panel Administrativo Global</h2>
        <p class="text-muted text-light-50">Resumen y métricas de almacenamiento e infraestructura de QualityDocc.</p>
    </div>

    <!-- Muestra errores o detalles de espacio en disco -->
    @if (ViewBag.DiskError != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.DiskError
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Fila de Tarjetas de Métricas -->
    <div class="row g-4 mb-5">
        <!-- Documentos Totales -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm" style="background-color: #E8D1A7; color: #1A130E; border-radius: 16px;">
                <div class="card-body d-flex align-items-center justify-content-between p-4">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 0.5px;">Documentos Totales</h6>
                        <h2 class="fw-bold mb-0">@ViewBag.TotalDocuments</h2>
                    </div>
                    <div class="fs-1"><i class="bi bi-folder-fill"></i></div>
                </div>
            </div>
        </div>

        <!-- Usuarios del Sistema -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm" style="background-color: #9D9167; color: #ffffff; border-radius: 16px;">
                <div class="card-body d-flex align-items-center justify-content-between p-4">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 0.5px;">Usuarios Activos</h6>
                        <h2 class="fw-bold mb-0">@ViewBag.TotalUsers</h2>
                    </div>
                    <div class="fs-1"><i class="bi bi-people-fill"></i></div>
                </div>
            </div>
        </div>

        <!-- Normas ISO -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm" style="background-color: #734F31; color: #ffffff; border-radius: 16px;">
                <div class="card-body d-flex align-items-center justify-content-between p-4">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 0.5px;">Normas ISO Creadas</h6>
                        <h2 class="fw-bold mb-0">@ViewBag.TotalIsos</h2>
                    </div>
                    <div class="fs-1"><i class="bi bi-shield-fill-check"></i></div>
                </div>
            </div>
        </div>

        <!-- Espacio en Disco -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm" style="background-color: #4A372C; color: #ffffff; border-radius: 16px; border: 1px solid #C2B3A5;">
                <div class="card-body d-flex align-items-center justify-content-between p-4">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 0.5px;">Espacio en Disco (Uploads)</h6>
                        <h2 class="fw-bold mb-0">@ViewBag.TotalDiskSpaceMB <span style="font-size: 1rem;">MB</span></h2>
                    </div>
                    <div class="fs-1 text-warning"><i class="bi bi-hdd-network-fill"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Accesos Rápidos de Administración -->
    <div class="row">
        <div class="col-12 col-lg-6 mb-4">
            <div class="card border-0 p-4 h-100" style="background-color: #4A372C; border-radius: 16px; color: #F5EBE1;">
                <h4 class="fw-bold mb-3 text-white"><i class="bi bi-gear-fill me-2 text-warning"></i>Gestión de Usuarios y Accesos</h4>
                <p>Administra las cuentas de los colaboradores de la organización, gestiona sus contraseñas, define los roles de acceso (Autor, Revisor, Lector) y garantiza el aislamiento de datos por empresa.</p>
                <div class="mt-auto">
                    <a href="/Admin/Users" class="btn btn-light w-100 py-2 fw-bold text-dark"><i class="bi bi-people me-1"></i> Ir a Gestionar Usuarios</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6 mb-4">
            <div class="card border-0 p-4 h-100" style="background-color: #4A372C; border-radius: 16px; color: #F5EBE1;">
                <h4 class="fw-bold mb-3 text-white"><i class="bi bi-shield-check me-2 text-warning"></i>Estructuración de ISOs</h4>
                <p>Agrega y actualiza las normas ISO que los autores podrán seleccionar al subir y actualizar la documentación de calidad.</p>
                <div class="mt-auto">
                    <a href="/Admin/Isos" class="btn btn-outline-light w-100 py-2 fw-bold"><i class="bi bi-shield me-1"></i> Ir a Gestión de ISO</a>
                </div>
            </div>
        </div>
    </div>
</div>
