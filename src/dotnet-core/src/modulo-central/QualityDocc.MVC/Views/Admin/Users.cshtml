@model IEnumerable<QualityDocc.Domain.Entities.User>
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Gestión de Usuarios - QualityDocc";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: var(--color-primary);"><i class="bi bi-people-fill me-2 text-warning"></i>Gestión de Usuarios</h2>
            <p class="text-muted m-0">Administra cuentas, contraseñas, roles y asignación multi-tenant por empresa.</p>
        </div>
        <button type="button" class="btn text-white fw-bold" style="background-color: var(--color-primary);" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="bi bi-person-plus-fill me-1"></i> Nuevo Usuario
        </button>
    </div>

    <!-- Alert de confirmación o error -->
    @if (TempData["UserSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["UserSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["UserError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["UserError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tabla de Usuarios -->
    <div class="card border-0 shadow-sm" style="background-color: #ffffff; border-radius: 16px; border: 1px solid #e5dec9; color: var(--text-main);">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="background-color: transparent;">
                    <thead>
                        <tr style="border-bottom: 2px solid #e5dec9;">
                            <th class="p-3 text-muted">ID</th>
                            <th class="p-3 text-muted">Nombre / Usuario</th>
                            <th class="p-3 text-muted">Correo Electrónico</th>
                            <th class="p-3 text-muted">Rol</th>
                            <th class="p-3 text-muted">Empresa Asignada</th>
                            <th class="p-3 text-center text-muted">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">No hay usuarios registrados en este momento.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var user in Model)
                            {
                                <tr style="border-bottom: 1px solid #e5dec9;">
                                    <td class="p-3 text-muted">USR-@user.Id</td>
                                    <td class="p-3 fw-bold text-dark">@user.Username</td>
                                    <td class="p-3 text-dark">@user.Email</td>
                                    <td class="p-3">
                                        @{
                                            var roleText = user.Role?.Name ?? "Sin Rol";
                                            var roleColor = "#72635a"; // default
                                            if (roleText == "SuperAdmin")
                                            {
                                                roleColor = "#8b0000"; // dark red
                                            }
                                            else if (roleText == "Administrator" || roleText == "Admin")
                                            {
                                                roleText = "Admin";
                                                roleColor = "#0d6efd"; // blue
                                            }
                                            else if (roleText == "Reviewer" || roleText == "Revisor")
                                            {
                                                roleText = "Revisor";
                                                roleColor = "#6f42c1"; // purple
                                            }
                                            else if (roleText == "Author" || roleText == "Autor")
                                            {
                                                roleText = "Autor";
                                                roleColor = "#198754"; // green
                                            }
                                            else if (roleText == "Approver" || roleText == "Aprobador")
                                            {
                                                roleText = "Aprobador";
                                                roleColor = "#fd7e14"; // orange
                                            }
                                            else if (roleText == "Reader" || roleText == "Lector")
                                            {
                                                roleText = "Lector";
                                                roleColor = "#6c757d"; // gray
                                            }
                                        }
                                        <span class="badge" style="font-size: 0.75rem; background-color: @roleColor !important; color: #ffffff;">@roleText</span>
                                    </td>
                                    <td class="p-3 text-dark">@(user.Company?.Name ?? "Ninguna (SuperAdmin)")</td>
                                    <td class="p-3 text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-warning" style="color: var(--color-accent); border-color: var(--color-accent);" onclick="loadEditUser(@user.Id)" title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <form asp-action="DeleteUser" method="post" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este usuario?');" style="display:inline;">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Crear Usuario -->
    <div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-dark">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="createUserModalLabel"><i class="bi bi-person-plus-fill me-2"></i>Registrar Nuevo Usuario</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreateUser" method="post">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre de Usuario:</label>
                            <input type="text" name="Username" class="form-control" placeholder="ej. juan_perez" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico:</label>
                            <input type="email" name="Email" class="form-control" placeholder="ej. juan@empresa1.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Contraseña:</label>
                            <input type="password" name="plainPassword" class="form-control" placeholder="Mínimo 5 caracteres" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Rol en el Sistema:</label>
                            <select name="RoleId" class="form-select" required>
                                @foreach (var role in (IEnumerable<QualityDocc.Domain.Entities.Role>)ViewBag.Roles)
                                {
                                    <option value="@role.Id">@role.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Empresa (Aislamiento Multi-tenant):</label>
                            <select name="CompanyId" class="form-select">
                                <option value="">Ninguna / SuperAdmin</option>
                                @foreach (var company in (IEnumerable<QualityDocc.Domain.Entities.Company>)ViewBag.Companies)
                                {
                                    <option value="@company.Id">@company.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn text-dark fw-bold" style="background-color: #E8D1A7;">Registrar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Editar Usuario -->
    <div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-dark">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="editUserModalLabel"><i class="bi bi-pencil-square me-2"></i>Editar Usuario</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="EditUser" method="post">
                    <input type="hidden" name="id" id="editUserId" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre de Usuario:</label>
                            <input type="text" name="username" id="editUsername" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico:</label>
                            <input type="email" name="email" id="editEmail" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Contraseña (Dejar vacío para no cambiar):</label>
                            <input type="password" name="plainPassword" class="form-control" placeholder="Nueva contraseña" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Rol en el Sistema:</label>
                            <select name="roleId" id="editRoleId" class="form-select" required>
                                @foreach (var role in (IEnumerable<QualityDocc.Domain.Entities.Role>)ViewBag.Roles)
                                {
                                    <option value="@role.Id">@role.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Empresa (Aislamiento Multi-tenant):</label>
                            <select name="companyId" id="editCompanyId" class="form-select">
                                <option value="">Ninguna / SuperAdmin</option>
                                @foreach (var company in (IEnumerable<QualityDocc.Domain.Entities.Company>)ViewBag.Companies)
                                {
                                    <option value="@company.Id">@company.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn text-white fw-bold bg-dark">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function loadEditUser(id) {
        fetch('/Admin/GetUser/' + id)
            .then(response => response.json())
            .then(data => {
                document.getElementById('editUserId').value = data.id;
                document.getElementById('editUsername').value = data.username;
                document.getElementById('editEmail').value = data.email;
                document.getElementById('editRoleId').value = data.roleId;
                document.getElementById('editCompanyId').value = data.companyId || '';
                
                var editModal = new bootstrap.Modal(document.getElementById('editUserModal'));
                editModal.show();
            })
            .catch(error => {
                alert('Error al cargar datos del usuario: ' + error);
            });
    }
</script>
