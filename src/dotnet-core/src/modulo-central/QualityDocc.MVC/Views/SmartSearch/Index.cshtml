@model IEnumerable<System.Text.Json.Nodes.JsonNode>

@{
    ViewData["Title"] = "Búsqueda Inteligente";
    var obsMapGlobal = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, List<string>>>(ViewBag.ObsoleteVersionsJson as string ?? "{}") ?? new Dictionary<string, List<string>>();
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-search-heart fs-1 me-3 text-warning" style="font-size: 2.5rem !important;"></i>
        <div>
            <h2 class="mb-0" style="color: #4a3b32; font-weight: 700;">Búsqueda Inteligente en MongoDB</h2>
            <p class="text-muted mb-0">Busca en los metadatos e indexa el contenido completo (cuerpo) de tus archivos PDF.</p>
        </div>
    </div>

    <!-- Barra de búsqueda principal -->
    <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px; background-color: #fcfaf5;">
        <form method="get" action="@Url.Action("Index", "SmartSearch")" class="row g-3">
            <div class="col-12">
                <div class="input-group input-group-lg">
                    <input type="text" name="q" class="form-control border-end-0" placeholder="Escribe palabras clave, normas o contenido del documento..." value="@ViewBag.SearchQuery" style="border-radius: 10px 0 0 10px; border-color: #ebd5ab; background-color: #fff;" required />
                    <button type="submit" class="btn text-white px-4 border-start-0" style="background-color: #9b9564; border-radius: 0 10px 10px 0; border-color: #ebd5ab;">
                        <i class="bi bi-search me-2"></i>Buscar
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Listado de resultados -->
    @if (Model != null && Model.Any())
    {
        <h5 class="mb-3 text-muted">Resultados encontrados (@Model.Count())</h5>



        <div class="row g-4" id="smart-search-results">
            @foreach (var doc in Model)
            {
                var title = doc["title"]?.ToString() ?? "Sin Título";
                var fileExtension = doc["fileExtension"]?.ToString() ?? "pdf";
                var body = doc["body"]?.ToString() ?? doc["textContent"]?.ToString() ?? "";
                var metadata = doc["metadata"];
                var author = metadata?["author"]?.ToString() ?? "Sistema";
                var version = metadata?["version"]?.ToString() ?? "1.0";
                var iso = metadata?["iso"]?.ToString() ?? "ISO General";
                var docId = metadata?["documentId"]?.ToString();

                // Truncar el cuerpo a unos 250 caracteres para la vista previa
                var snippet = body.Length > 250 ? body.Substring(0, 250) + "..." : body;

                // Leer versiones obsoletas desde el mapa global
                var docIdStr = metadata?["documentId"]?.ToString() ?? "0";
                var obsoleteJsonList = obsMapGlobal.ContainsKey(docIdStr) ? obsMapGlobal[docIdStr] : new List<string>();
                var obsoleteVersions = new List<System.Text.Json.Nodes.JsonNode>();
                foreach (var oj in obsoleteJsonList)
                {
                    try { var n = System.Text.Json.Nodes.JsonNode.Parse(oj); if (n != null) obsoleteVersions.Add(n); } catch { }
                }
                int currentDocId = 0;
                int.TryParse(docIdStr, out currentDocId);

                <div class="col-12 search-result-item">
                    <div class="card shadow-sm border-0 p-4 h-100" style="border-radius: 12px; border-left: 5px solid #9b9564 !important; transition: transform 0.2s;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <span class="badge bg-secondary mb-2 font-sans me-2">@iso</span>
                                <span class="badge bg-light text-dark border mb-2 font-sans">v@(version)</span>
                                <h4 class="fw-bold mb-1" style="color: #6e4c30;">@title</h4>
                                <p class="text-muted mb-0" style="font-size: 0.85rem;">
                                    <i class="bi bi-person me-1"></i> Autor: <strong>@author</strong>
                                </p>
                            </div>
                            <span class="badge bg-dark font-sans text-uppercase">@fileExtension</span>
                        </div>

                        <hr class="my-3 opacity-50" />

                        <div class="mb-3">
                            <h6 class="fw-bold mb-1" style="color: #4a3b32; font-size: 0.9rem;"><i class="bi bi-file-earmark-text-fill me-1"></i> Vista previa del contenido extraído:</h6>
                            <p class="text-muted fst-italic mb-0" style="font-size: 0.9rem; background-color: #faf8f5; padding: 10px; border-radius: 8px;">
                                @(string.IsNullOrWhiteSpace(snippet) ? "No se pudo extraer texto indexado de este PDF." : snippet)
                            </p>
                        </div>

                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                            <div>
                                @if (obsoleteVersions.Count > 0)
                                {
                                    <button class="btn btn-sm btn-link p-0 text-decoration-none d-flex align-items-center gap-1"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#obs-versions-@currentDocId"
                                            aria-expanded="false"
                                            style="font-size: 0.8rem; color: #805ad5;">
                                        <i class="bi bi-clock-history"></i>
                                        Ver versiones anteriores (@obsoleteVersions.Count)
                                    </button>
                                    <div class="collapse mt-2" id="obs-versions-@currentDocId">
                                        <ul class="list-group list-group-flush border rounded-3 p-2 shadow-sm" style="font-size: 0.85rem; background-color: #faf8f5; max-width: 380px;">
                                            @foreach (var obsDoc in obsoleteVersions)
                                            {
                                                var obsVersion = obsDoc["metadata"]?["version"]?.ToString() ?? "?";
                                                <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center py-2 px-1 border-light">
                                                    <span class="fw-bold text-dark">v@(obsVersion)</span>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="badge py-1 px-2" style="background-color: #6c757d; font-size: 0.75rem;">Obsoleto</span>
                                                        <span class="text-muted" title="Versiones obsoletas no se pueden descargar (Solo Auditoría)">
                                                            <i class="bi bi-lock-fill" style="font-size: 0.8rem;"></i>
                                                        </span>
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(docId))
                            {
                                <a href="/Home/Index" class="btn btn-sm text-white px-3" style="background-color: #9b9564;">
                                    <i class="bi bi-file-earmark-check-fill me-1"></i> Ir al Portal Central
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div id="pagination-container" class="d-flex justify-content-center mt-4 mb-3"></div>
    }
    else if (ViewBag.SearchQuery != null)
    {
        <div class="alert alert-warning text-center py-5 shadow-sm" style="border-radius: 15px; background-color: #fefcf7; border: 1px solid #ebd5ab;">
            <i class="bi bi-folder-x display-1 text-warning opacity-75 mb-3 d-block"></i>
            <h4 class="fw-bold" style="color: #6e4c30;">No se encontraron resultados</h4>
            <p class="text-muted mb-0">Intenta buscar con palabras clave diferentes o verifica que el documento esté en estado <strong>Aprobado</strong>.</p>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted opacity-75">
            <i class="bi bi-search display-3 mb-3 d-block"></i>
            <p>Ingresa una consulta en la barra superior para iniciar la búsqueda de documentos.</p>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const resultsContainer = document.getElementById("smart-search-results");
        if (!resultsContainer) return;

        const items = Array.from(resultsContainer.querySelectorAll(".search-result-item"));
        const itemsPerPage = 10;
        let currentPage = 1;
        const totalPages = Math.ceil(items.length / itemsPerPage);

        if (totalPages <= 1) return;

        const container = document.getElementById("pagination-container");
        if (!container) return;

        function showPage(page) {
            currentPage = page;
            const start = (page - 1) * itemsPerPage;
            const end = start + itemsPerPage;

            items.forEach((item, index) => {
                if (index >= start && index < end) {
                    item.style.setProperty("display", "block", "important");
                } else {
                    item.style.setProperty("display", "none", "important");
                }
            });

            renderPagination();
        }

        function renderPagination() {
            container.innerHTML = "";
            const nav = document.createElement("nav");
            const ul = document.createElement("ul");
            ul.className = "pagination gap-1 justify-content-center";

            // Botón Anterior
            const prevLi = document.createElement("li");
            prevLi.className = "page-item " + (currentPage === 1 ? "disabled" : "");
            prevLi.innerHTML = `<button class="page-link rounded" style="color: #4a3b32; border-color: #ebd5ab; background-color: #fff;"><i class="bi bi-chevron-left"></i></button>`;
            prevLi.onclick = function() {
                if (currentPage > 1) showPage(currentPage - 1);
            };
            ul.appendChild(prevLi);

            // Páginas
            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement("li");
                li.className = "page-item " + (currentPage === i ? "active" : "");
                const btn = document.createElement("button");
                btn.className = "page-link rounded fw-bold";
                btn.textContent = i;

                if (currentPage === i) {
                    btn.style.backgroundColor = "#9b9564";
                    btn.style.borderColor = "#9b9564";
                    btn.style.color = "#fff";
                } else {
                    btn.style.color = "#4a3b32";
                    btn.style.borderColor = "#ebd5ab";
                    btn.style.backgroundColor = "#fff";
                }

                li.appendChild(btn);
                li.onclick = function() {
                    showPage(i);
                };
                ul.appendChild(li);
            }

            // Botón Siguiente
            const nextLi = document.createElement("li");
            nextLi.className = "page-item " + (currentPage === totalPages ? "disabled" : "");
            nextLi.innerHTML = `<button class="page-link rounded" style="color: #4a3b32; border-color: #ebd5ab; background-color: #fff;"><i class="bi bi-chevron-right"></i></button>`;
            nextLi.onclick = function() {
                if (currentPage < totalPages) showPage(currentPage + 1);
            };
            ul.appendChild(nextLi);

            nav.appendChild(ul);
            container.appendChild(nav);
        }

        showPage(1);
    });
</script>
